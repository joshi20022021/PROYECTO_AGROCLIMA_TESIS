skinparam shadowing false
skinparam backgroundColor white
skinparam componentStyle rectangle

folder "Fuentes externas" as Sources {
  component "ERA5-Land\n(CDS API)" as ERA5
  component "FAOSTAT\n(rendimientos GT)" as FAOSTAT
  component "INSIVUMEH\n(estaciones meteorologicas)" as INSIVUMEH
  component "NASA POWER\n(climatologia)" as NASA
  component "SoilGrids\n(propiedades suelo)" as SoilGrids
  component "Open-Meteo\n(pronostico en vivo)" as OpenMeteo
}

folder "scripts/download/" as Download {
  component "era5_client.py" as DL_ERA5
  component "insivumeh_client.py" as DL_INSI
  component "nasa_power_client.py" as DL_NASA
  component "soilgrids_client.py" as DL_SOIL
  component "open_meteo_client.py" as DL_OM
