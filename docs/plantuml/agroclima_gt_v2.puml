' ── 13. Arquitectura de componentes frontend/backend ─────────

@startuml AgroClimaGT_Componentes
title AgroClima GT - Arquitectura de componentes
top to bottom direction
skinparam shadowing false
skinparam backgroundColor white
skinparam componentStyle rectangle

package "Frontend React (Vite)" as FE {
  package "Paginas - Usuario" as PU {
    component "Dashboard\n(prediccion + metricas)" as P_DASH
    component "Metricas\n(datos climaticos)" as P_MET
    component "Mapa de Riesgo\n(departamentos GT)" as P_MAP
    component "Alertas\n(umbrales y acciones)" as P_ALERT
    component "Resultados\n(reporte y feedback)" as P_REP
    component "Pronostico\n(7 dias + calendario)" as P_FORE
    component "Arduino\n(sensores en vivo)" as P_ARD
  }

  package "Paginas - Admin" as PA {
    component "AdminDashboard\n(KPIs del sistema)" as A_DASH
    component "AdminDatasets\n(inventario de datos)" as A_DS
    component "AdminPredictions\n(historial)" as A_PRED
    component "AdminReadings\n(lecturas Arduino)" as A_READ
    component "Models\n(modelo ML + comparacion)" as A_MDL
  }

  package "Servicios" as SVC {
    component "api.js\n(cliente HTTP REST)" as API_SVC
    component "Login / Auth\n(sessionStorage)" as AUTH
  }
}

package "Backend FastAPI :8000" as BE {
  package "Endpoints REST" as EP {
    component "POST /predict" as EP1
    component "GET /metrics" as EP2
    component "GET /forecast/{mun}" as EP3
    component "GET /risk-map" as EP4
    component "GET /alerts" as EP5
    component "GET /dataset" as EP6
    component "POST /feedback" as EP7
    component "GET /model-info" as EP8
    component "POST /admin/train" as EP9
    component "POST /auth/login" as EP10
    component "GET /admin/datasets" as EP11
    component "GET /predictions" as EP12
    component "GET /arduino/readings" as EP13
  }

  component "WebSocket /ws/arduino" as WS

  package "core/" as CORE {
    component "ml_insights.py" as ML
    component "alert_engine.py" as AE
    component "arduino_reader.py" as AR
    component "email_notifier.py" as EN
  }

  package "database/" as DBPKG {
    component "repository.py" as REPO
    component "connection.py" as CONN
  }
}

