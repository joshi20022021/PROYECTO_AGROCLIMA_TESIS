  artifact "faostat_yields_guatemala.csv" as SRC_FAO
  artifact "insivumeh_recent_mensual.csv" as SRC_INSI
  artifact "nasa_power_mensual.csv" as SRC_NASA
  artifact "soilgrids_suelo.csv" as SRC_SOIL
}

folder "scripts/datasets/" as Datasets {
  component "generate_dataset_era5.py" as GEN_ERA5
