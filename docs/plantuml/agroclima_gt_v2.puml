' ── 9. Sensores y Arduino ─────────────────────────────────────

@startuml AgroClimaGT_Diagrama_Sensores
title AgroClima GT - Diagrama de sensores y conexion Arduino
left to right direction
skinparam shadowing false
skinparam backgroundColor white
skinparam componentStyle rectangle

node "Modulo fisico de sensores" {
  component "Arduino UNO/MEGA" as Arduino
  component "Protoboard 830" as Proto
  component "DS18B20\nTemperatura" as DS18B20
  component "Higrometro capacitivo\nHumedad del suelo" as Soil
  component "TSL2561\nIntensidad de luz" as Light
  component "TCS3200\nColor RGB / verdor" as Color
  component "Bateria 9V + clip\nAlimentacion auxiliar" as Battery
  component "Resistencias, jumpers,\nalambres y aislante" as Wiring
}

node "Computadora local" {
  component "Backend FastAPI\ncore/arduino_reader.py\nPySerial + WebSocket" as Backend
  component "Frontend React/Vite\nPagina Arduino" as Frontend
}

cloud "Red local / WiFi" as Wifi

DS18B20 --> Proto : senal 1-Wire
Soil --> Proto : salida analogica
Light --> Proto : I2C
Color --> Proto : senales digitales RGB
Battery --> Proto : alimentacion auxiliar
Wiring --> Proto : conexion fisica
Proto --> Arduino : pines de entrada/salida
Arduino --> Backend : USB tipo B / serial
Backend --> Frontend : WebSocket :8000/ws/arduino
Frontend --> Wifi : acceso desde navegador
@enduml


' ── 10. Despliegue ───────────────────────────────────────────

@startuml AgroClimaGT_Despliegue
title AgroClima GT - Diagrama de Despliegue
left to right direction
skinparam componentStyle rectangle

cloud "GitHub Pages" as GitHubPages {
  artifact "Frontend publicado\nbuild / dist" as FrontendDeploy
}

node "PC / Laptop del usuario" as ClientNode {
  artifact "Navegador Web" as Browser
}

node "Host local Windows" as Host {
  node "Proceso Uvicorn :8000" as Uvicorn {
    artifact "FastAPI\nbackend/api.py" as API
    folder "backend/core/" as Core {
      artifact "ml_insights.py\nXGBoost + SHAP + anomalia" as ML
      artifact "arduino_reader.py\nPySerial + WebSocket" as Reader
      artifact "alert_engine.py\nUmbrales y severidad" as AlertEngine
      artifact "email_notifier.py\nSMTP + throttle" as Mailer
    }
    folder "backend/database/" as DB {
      artifact "connection.py\npsycopg2 pool" as DBConn
      artifact "repository.py\nCRUD y sincronizacion" as DBRepo
    }
  }

  folder "backend/data/models/" as ModelStore {
    artifact "xgboost_yield.joblib" as ModelFile
    artifact "label_encoders.joblib" as Encoders
    artifact "isolation_forest_sensor.joblib" as IsoForest
    artifact "drift_profile.json" as DriftProfile
    artifact "model_comparison.json" as ModelComp
    artifact "dataset_meta.json" as DatasetMeta
  }

  folder "backend/data/datasets/" as Datasets {
    artifact "dataset_faostat.csv\n(2.1 M filas)" as FAOData
    artifact "dataset_combinado.csv" as CombData
    artifact "crop_optimal_conditions.csv" as CropRef
    artifact "recommendations.csv" as RecomData
  }

  folder "backend/logs/" as Logs {
    artifact "uvicorn.out.log" as LogOut
    artifact "uvicorn.err.log" as LogErr
  }

  node "Docker Engine" as Docker {
    node "Contenedor PostgreSQL 16" as PgContainer {
      database "agroclima_db :5435" as PostgreSQL
    }
  }
}

node "Dispositivo fisico" as Edge {
  device "Arduino + sensores\n(DS18B20, TSL2561,\nTCS3200, Higrometro)" as Arduino
}

cloud "API Open-Meteo (gratuita)" as OpenMeteo
cloud "Servidor SMTP" as SMTP

Browser --> GitHubPages : abre pagina web
GitHubPages --> Browser : entrega interfaz React
Browser --> API : HTTP REST / WebSocket
API --> PostgreSQL : predicciones, lecturas, alertas
API --> ModelFile : carga modelo XGBoost
API --> FAOData : dataset entrenamiento/mapa
API --> CropRef : rangos optimos por cultivo
Reader --> Arduino : USB serial (PySerial)
API --> OpenMeteo : pronostico 7 dias
Mailer --> SMTP : alertas criticas por correo
API --> Logs : registro de errores
@enduml


