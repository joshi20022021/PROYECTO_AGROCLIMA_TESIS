' ── 12. Esquema de base de datos ─────────────────────────────

@startuml AgroClimaGT_Esquema_BD
title AgroClima GT - Esquema de base de datos PostgreSQL
skinparam shadowing false
skinparam backgroundColor white
skinparam linetype ortho

entity "usuarios" as USR {
  * id : SERIAL <<PK>>
  --
  nombre : VARCHAR(100)
  email : VARCHAR(150) <<UNIQUE>>
  password_hash : VARCHAR(255)
  rol : VARCHAR(20)
  creado_en : TIMESTAMP
}

entity "predicciones" as PRED {
  * id : SERIAL <<PK>>
  --
  timestamp : TIMESTAMP
  municipio : VARCHAR(100)
  cultivo : VARCHAR(100)
  mes : SMALLINT
  temperatura : FLOAT
  precipitacion : FLOAT
  humedad : FLOAT
  ph_suelo : FLOAT
  soil_moisture : FLOAT
  light_lux : FLOAT
  greenness_idx : FLOAT
  swvl2 : FLOAT
  swvl3 : FLOAT
  soil_temp : FLOAT
  temp_max : FLOAT
  temp_min : FLOAT
  wind_speed : FLOAT
  yield_pct : FLOAT
  yield_level : VARCHAR(20)
  fuente : VARCHAR(20)
  modelo_ver : VARCHAR(50)
}

entity "lecturas_arduino" as LECT {
  * id : SERIAL <<PK>>
  --
  timestamp : TIMESTAMP
  municipio : VARCHAR(100)
  cultivo : VARCHAR(100)
  temperatura : FLOAT
  humedad : FLOAT
  soil_moisture : FLOAT
  light_lux : FLOAT
  greenness_idx : FLOAT
  ph_suelo : FLOAT
  precipitacion : FLOAT
  raw_json : JSONB
}

entity "alertas" as ALERT {
  * id : SERIAL <<PK>>
  --
  timestamp : TIMESTAMP
  prediccion_id : INTEGER <<FK>>
  municipio : VARCHAR(100)
  cultivo : VARCHAR(100)
  variable : VARCHAR(50)
  condicion : VARCHAR(20)
  severidad : VARCHAR(20)
  mensaje : TEXT
}

entity "modelos_ml" as MDL {
  * id : SERIAL <<PK>>
  --
  nombre : VARCHAR(100)
  version : VARCHAR(50)
  fecha_entrenamiento : TIMESTAMP
  dataset_usado : VARCHAR(200)
  n_filas : INTEGER
  n_features : INTEGER
  r2_test : FLOAT
  mae : FLOAT
  rmse : FLOAT
  precision : FLOAT
  recall : FLOAT
  f1 : FLOAT
  low_yield_threshold : INTEGER
  crossval_r2 : FLOAT
  crossval_std : FLOAT
  hiperparametros : JSONB
  activo : BOOLEAN
}

entity "datasets_registrados" as DS {
  * id : SERIAL <<PK>>
  --
  nombre_archivo : VARCHAR(200) <<UNIQUE>>
  tipo : VARCHAR(50)
  origen : VARCHAR(100)
  periodo : VARCHAR(50)
  total_filas : INTEGER
  total_columnas : INTEGER
  columnas : JSONB
  metadata : JSONB
  activo : BOOLEAN
  fecha_carga : TIMESTAMP
}

entity "fuentes_datos" as FUENTE {
  * id : SERIAL <<PK>>
  --
  nombre_archivo : VARCHAR(200) <<UNIQUE>>
  categoria : VARCHAR(50)
  periodo : VARCHAR(50)
  total_filas : INTEGER
  total_columnas : INTEGER
  columnas : JSONB
  metadata : JSONB
  fecha_carga : TIMESTAMP
}

entity "metricas_climaticas" as MET {
