# ── Configuración de correo para alertas críticas ─────────────────────────
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas .env a git (ya está en .gitignore).

# Servidor SMTP (Gmail por defecto)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Credenciales de Gmail
# Para Gmail necesitas una "Contraseña de aplicación" (no tu contraseña normal):
#   Mi cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de app
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Correo remitente (puede ser igual a SMTP_USER)
ALERT_EMAIL_FROM=tucorreo@gmail.com

# Destinatario(s) — separa varios con coma
ALERT_EMAIL_TO=destinatario@gmail.com

# Minutos de espera mínimo entre correos del mismo tipo de alerta (default: 30)
ALERT_COOLDOWN_MIN=30
